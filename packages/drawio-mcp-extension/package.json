{
  "name": "drawio-mcp-extension",
  "description": "Draw.io MCP Extension providing services to Draw.io MCP Server",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "dev:plugin": "MODE=plugin wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "build:plugin": "MODE=plugin wxt build",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "zip:plugin": "MODE=plugin wxt zip",
    "compile": "tsc --noEmit",
    "test:iframe-host": "tsx scripts/serve-iframe-host.ts",
    "postinstall": "wxt prepare"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "server",
    "draw.io",
    "drawio",
    "diagrams.net",
    "diagramsnet",
    "diagram",
    "claude"
  ],
  "author": "Ladislav Gazo",
  "license": "MIT",
  "packageManager": "pnpm@10.8.1",
  "dependencies": {
    "drawio-mcp-plugin": "workspace:*",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@wxt-dev/module-react": "1.2.2",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "wxt": "0.20.20"
  }
}
